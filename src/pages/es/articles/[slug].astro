---
import PageLayout from '../../../layouts/PageLayout.astro'
import Tag from '../../../components/ui/Tag.astro'
import { getArticle, getAllArticleSlugs } from '../../../lib/articles'
import { renderMarkdown } from '../../../lib/markdown'

export async function getStaticPaths() {
  const slugs = getAllArticleSlugs()
  return slugs.map(slug => ({ params: { slug } }))
}

const { slug } = Astro.params
const article = getArticle(slug!, 'es')
const contentHtml = await renderMarkdown(article.content)
---

<PageLayout title={`${article.title} — Wildiney Di Masi`} locale="es">
  <!-- Dark header with background image -->
  <div class="relative min-h-[72vh] bg-dark flex items-end pt-24 pb-16 overflow-hidden">
    {article.thumbnail && (
      <div class="absolute inset-0">
        <img
          src={article.thumbnail}
          alt=""
          aria-hidden="true"
          width="1280"
          height="720"
          class="w-full h-full object-cover hero-image"
        />
      </div>
    )}
    <div class="w-full px-6 md:px-12 lg:px-24">
      <div class="max-w-3xl mx-auto">
      <div class="relative">
        <div class="absolute -inset-16 backdrop-blur-md bg-dark/60 border border-white/[0.07]"></div>
        <div class="relative hero-text">
          <a href="/es/articles/" class="inline-flex items-center gap-1.5 text-xs text-muted hover:text-accent transition-colors uppercase tracking-widest mb-6">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
            Artículos
          </a>
          {article.date && (
            <p class="text-xs text-muted font-mono mb-3">
              {new Date(article.date).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
          )}
          <h1 class="font-display text-3xl md:text-4xl font-black text-dark-text leading-tight mb-4">
            {article.title}
          </h1>
          {article.description && (
            <p class="text-muted text-lg leading-relaxed mb-6">{article.description}</p>
          )}
          {article.tags && article.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {article.tags.map(tag => <Tag>{tag}</Tag>)}
            </div>
          )}
        </div>
      </div>
      </div>
    </div>
  </div>

  <!-- Light body -->
  <div class="bg-paper text-ink px-6 md:px-12 lg:px-24 py-16">
    <div class="max-w-3xl mx-auto prose prose-lg" set:html={contentHtml} />
    <div class="max-w-3xl mx-auto mt-16 pt-8 border-t border-rule">
      <a href="/es/articles/" class="inline-flex items-center gap-1.5 text-xs text-ink/50 hover:text-accent uppercase tracking-widest transition-colors">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Artículos
      </a>
    </div>
  </div>
</PageLayout>
