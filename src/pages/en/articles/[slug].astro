---
import PageLayout from '../../../layouts/PageLayout.astro'
import { getArticle, getAllArticleSlugs } from '../../../lib/articles'
import { renderMarkdown } from '../../../lib/markdown'

export async function getStaticPaths() {
  const slugs = getAllArticleSlugs()
  return slugs.map(slug => ({ params: { slug } }))
}

const { slug } = Astro.params
const article = getArticle(slug!, 'en')
const contentHtml = await renderMarkdown(article.content)
---

<PageLayout title={`${article.title} — Wildiney Di Masi`} locale="en">
  <!-- Dark header -->
  <div class="bg-dark pt-24 pb-12 px-6 md:px-12 lg:px-24">
    <div class="max-w-3xl mx-auto">
      <a href="/en/articles/" class="text-xs text-muted hover:text-accent transition-colors uppercase tracking-widest">
        ← Articles
      </a>
      {article.date && (
        <p class="text-xs text-muted font-mono mt-6 mb-3">
          {new Date(article.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
      )}
      <h1 class="font-display text-3xl md:text-4xl font-black text-dark-text leading-tight mb-4">
        {article.title}
      </h1>
      {article.description && (
        <p class="text-muted text-lg leading-relaxed mb-6">{article.description}</p>
      )}
      {article.tags && article.tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {article.tags.map(tag => (
            <span class="text-xs uppercase tracking-widest border border-dark-border text-muted px-2 py-0.5">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </div>

  {article.thumbnail && (
    <div class="bg-dark px-6 md:px-12 lg:px-24 pb-0">
      <div class="max-w-3xl mx-auto">
        <img
          src={article.thumbnail}
          alt={article.title}
          class="w-full aspect-video object-cover"
        />
      </div>
    </div>
  )}

  <!-- Light body -->
  <div class="bg-paper text-ink px-6 md:px-12 lg:px-24 py-16">
    <div class="max-w-3xl mx-auto prose prose-lg" set:html={contentHtml} />
  </div>
</PageLayout>
