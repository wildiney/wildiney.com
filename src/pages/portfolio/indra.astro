---
import PageLayout from '../../layouts/PageLayout.astro'
import Tag from '../../components/ui/Tag.astro'
import { getCaseStudy } from '../../lib/caseStudies'
import { getTranslations } from '../../i18n/index'
import { renderMarkdown } from '../../lib/markdown'

const locale = 'pt'
const cs = getCaseStudy('indra', locale)
const t = getTranslations(locale)
const contentHtml = await renderMarkdown(cs.content)
---

<PageLayout title={`${cs.title} — Wildiney Di Masi`} locale={locale}>
  <!-- Dark header with background image -->
  <div class="relative min-h-[72vh] bg-dark flex items-end pt-32 pb-16 overflow-hidden">
    {cs.thumbnail && (
      <div class="absolute inset-0">
        <img
          src={cs.thumbnail}
          alt=""
          aria-hidden="true"
          width="1280"
          height="720"
          class="w-full h-full object-cover hero-image"
        />
      </div>
    )}
    <div class="w-full px-6 md:px-12 lg:px-24">
      <div class="max-w-3xl mx-auto">
        <div class="relative">
          <div class="absolute -inset-16 backdrop-blur-md bg-dark/60 border border-white/[0.07]"></div>
          <div class="relative hero-text">
            <p class="text-xs text-accent uppercase tracking-widest mb-3">{t.portfolio.caseStudy}</p>
            <h1 class="font-display text-4xl md:text-5xl font-black text-dark-text mb-4">{cs.title}</h1>
            <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-muted mb-4">
              {cs.company && <span>{cs.company}</span>}
              {cs.role && <><span class="text-muted/30" aria-hidden="true">·</span><span>{cs.role}</span></>}
              {cs.year && <><span class="text-muted/30" aria-hidden="true">·</span><span>{cs.year}</span></>}
            </div>
            {cs.tags && cs.tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {cs.tags.map(tag => <Tag>{tag}</Tag>)}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Light body -->
  <div class="bg-paper text-ink px-6 md:px-12 lg:px-24 py-20">
    <div class="max-w-3xl mx-auto prose prose-lg" set:html={contentHtml} />
    <div class="max-w-3xl mx-auto mt-16 pt-8 border-t border-rule">
      <a href="/#portfolio" class="inline-flex items-center gap-1.5 text-xs text-ink/50 hover:text-accent uppercase tracking-widest transition-colors">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        {t.nav.portfolio}
      </a>
    </div>
  </div>
</PageLayout>
