---
import PageLayout from '../../layouts/PageLayout.astro'
import Tag from '../../components/ui/Tag.astro'
import { getArticles } from '../../lib/articles'

const articles = getArticles('pt').sort((a, b) =>
  (b.date ?? '').localeCompare(a.date ?? '')
)
---

<PageLayout title="Artigos — Wildiney Di Masi" locale="pt">
  <div class="max-w-5xl mx-auto px-6 md:px-12 lg:px-24 py-24 pt-32">
    <p class="text-xs text-accent uppercase tracking-widest mb-4">Artigos</p>
    <h1 class="font-display text-4xl font-black text-dark-text mb-12">Perspectivas</h1>
    <div class="space-y-4">
      {articles.map(article => (
        <a
          href={`/articles/${article.slug}/`}
          class="group flex flex-col sm:flex-row gap-6 bg-dark-surface border border-dark-border p-6 shadow-[var(--shadow-card)] hover:-translate-y-1 hover:shadow-[var(--shadow-card-hover)] hover:border-accent/50 transition-all duration-200"
        >
          {article.thumbnail && (
            <div class="sm:w-48 sm:flex-shrink-0">
              <img
                src={article.thumbnail}
                alt=""
                width="192"
                height="108"
                loading="lazy"
                class="w-full aspect-video object-cover opacity-80 group-hover:opacity-100 transition-opacity"
              />
            </div>
          )}
          <div class="flex-1 flex flex-col justify-center">
            {article.date && (
              <p class="text-xs text-muted font-mono mb-2">
                {new Date(article.date).toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
            )}
            <h2 class="text-lg font-semibold text-dark-text group-hover:text-accent transition-colors mb-2">
              {article.title}
            </h2>
            {article.description && (
              <p class="text-sm text-muted leading-relaxed">{article.description}</p>
            )}
            {article.tags && article.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mt-3">
                {article.tags.map(tag => <Tag>{tag}</Tag>)}
              </div>
            )}
          </div>
          <span class="hidden sm:flex items-center text-muted group-hover:text-accent transition-colors text-xl self-center">→</span>
        </a>
      ))}
      {articles.length === 0 && <p class="text-muted pt-8">Artigos em breve.</p>}
    </div>
  </div>
</PageLayout>
