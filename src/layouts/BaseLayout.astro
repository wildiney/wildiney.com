---
import '../styles/globals.css'
import CookieConsent from '../components/CookieConsent.astro'
import type { Locale } from '../i18n/index'

interface Props {
  title?: string
  description?: string
  locale?: Locale
  noindex?: boolean
  ogImage?: string
  structuredData?: Record<string, unknown> | Record<string, unknown>[]
}

const {
  title = 'Wildiney Di Masi — Product Manager',
  description = 'Wildiney Di Masi - Product Management. Entregando produtos que geram impacto.',
  locale = 'pt',
  noindex = false,
  ogImage,
  structuredData,
} = Astro.props

const isProd = import.meta.env.PROD
const gtmId = isProd ? (import.meta.env.PUBLIC_GTM_ID ?? 'GTM-NNX4S37') : null
const clarityId = isProd ? (import.meta.env.PUBLIC_CLARITY_ID ?? 'vygjr8jgps') : null
const siteBase = Astro.site || 'https://www.wildiney.com'
const siteUrl = new URL(Astro.url.pathname, siteBase)
const ogImageUrl = new URL(ogImage ?? '/assets/og-image.jpg', siteBase).toString()

// Irregular slugs that don't share a path across locales
const IRREGULAR_ALTERNATES: Record<string, { pt: string; en: string; es: string }> = {
  '/privacidade/': { pt: '/privacidade/', en: '/en/privacy/', es: '/es/privacidad/' },
  '/en/privacy/': { pt: '/privacidade/', en: '/en/privacy/', es: '/es/privacidad/' },
  '/es/privacidad/': { pt: '/privacidade/', en: '/en/privacy/', es: '/es/privacidad/' },
}

function getAlternates(pathname: string): { pt: string; en: string; es: string } | null {
  if (IRREGULAR_ALTERNATES[pathname]) return IRREGULAR_ALTERNATES[pathname]
  let basePath = pathname
  if (basePath.startsWith('/en/')) basePath = basePath.slice(3)
  else if (basePath.startsWith('/es/')) basePath = basePath.slice(3)
  if (basePath === '') basePath = '/'
  const pt = basePath
  const en = basePath === '/' ? '/en/' : `/en${basePath}`
  const es = basePath === '/' ? '/es/' : `/es${basePath}`
  return { pt, en, es }
}

const alternates = noindex ? null : getAlternates(Astro.url.pathname)
const structuredDataList = structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : []
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={siteUrl.toString()} />
    {alternates && (
      <>
        <link rel="alternate" hreflang="pt" href={new URL(alternates.pt, siteBase).toString()} />
        <link rel="alternate" hreflang="en" href={new URL(alternates.en, siteBase).toString()} />
        <link rel="alternate" hreflang="es" href={new URL(alternates.es, siteBase).toString()} />
        <link rel="alternate" hreflang="x-default" href={new URL(alternates.pt, siteBase).toString()} />
      </>
    )}
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl.toString()} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {structuredDataList.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Inter:wght@300..700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    {(gtmId || clarityId) && (
      <script define:vars={{ gtmId, clarityId }}>
        /* global gtmId, clarityId -- injected by Astro's define:vars */
        window.__initAnalytics = function () {
          if (['localhost', '127.0.0.1'].includes(window.location.hostname)) return
          if (localStorage.getItem('lgpd_consent') !== 'accepted') return
          if (window.__analyticsLoaded) return
          window.__analyticsLoaded = true
          if (gtmId) {
            ;(function (w, d, s, l, i) {
              w[l] = w[l] || []
              w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' })
              var f = d.getElementsByTagName(s)[0],
                j = d.createElement(s),
                dl = l != 'dataLayer' ? '&l=' + l : ''
              j.async = true
              j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl
              f.parentNode.insertBefore(j, f)
            })(window, document, 'script', 'dataLayer', gtmId)
          }
          if (clarityId) {
            ;(function (c, l, a, r, i, t, y) {
              c[a] = c[a] || function () { ;(c[a].q = c[a].q || []).push(arguments) }
              t = l.createElement(r)
              t.async = 1
              t.src = 'https://www.clarity.ms/tag/' + i
              y = l.getElementsByTagName(r)[0]
              y.parentNode.insertBefore(t, y)
            })(window, document, 'clarity', 'script', clarityId)
          }
        }
        window.__initAnalytics()
      </script>
    )}
  </head>
  <body>
    <a href="#main-content" class="sr-only focus-visible:not-sr-only focus-visible:fixed focus-visible:top-4 focus-visible:left-4 focus-visible:z-200 focus-visible:px-4 focus-visible:py-2 focus-visible:bg-accent focus-visible:text-dark focus-visible:text-sm focus-visible:font-medium">
      Pular para o conteúdo
    </a>
    <slot />
    <CookieConsent locale={locale} />
  </body>
</html>
