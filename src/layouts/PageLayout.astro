---
import BaseLayout from './BaseLayout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import { type Locale } from '../i18n/index'

interface Props {
  title?: string
  description?: string
  locale?: Locale
  noindex?: boolean
}

const {
  title,
  description,
  locale = 'pt',
  noindex = false,
} = Astro.props
---

<BaseLayout title={title} description={description} locale={locale} noindex={noindex}>
  <Header locale={locale} />
  <main id="main-content" class="pt-16">
    <slot />
  </main>
  <Footer locale={locale} />
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(({ target, isIntersecting }) => {
        if (isIntersecting) {
          target.classList.add('is-visible')
          observer.unobserve(target)
        }
      })
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  )
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el))

  // Kinetic headings: split into word spans and reveal on enter
  const kineticEls = document.querySelectorAll<HTMLElement>('.kinetic-heading')
  kineticEls.forEach((el) => {
    let wordIndex = 0
    const frag = document.createDocumentFragment()
    Array.from(el.childNodes).forEach((node) => {
      if (node.nodeType === Node.TEXT_NODE) {
        const parts = (node.textContent ?? '').split(/(\s+)/)
        parts.forEach((part) => {
          if (part === '') return
          if (part.trim() === '') {
            frag.appendChild(document.createTextNode(part))
          } else {
            const span = document.createElement('span')
            span.className = 'word'
            span.style.setProperty('--i', String(wordIndex++))
            span.textContent = part
            frag.appendChild(span)
          }
        })
      } else {
        frag.appendChild(node.cloneNode(true))
      }
    })
    el.innerHTML = ''
    el.appendChild(frag)
  })

  const kineticObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-in')
          kineticObs.unobserve(entry.target)
        }
      })
    },
    { threshold: 0.4 }
  )
  kineticEls.forEach((el) => kineticObs.observe(el))

  // Micro-interactions (Ideia 2): magnetic buttons + 3D tilt cards + link swipe
  const hasHover = window.matchMedia('(hover: hover)').matches
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

  if (hasHover && !reducedMotion) {
    // Magnetic buttons
    document.querySelectorAll<HTMLElement>('[data-magnetic]').forEach((btn) => {
      const RADIUS = 70
      const STRENGTH = 0.22
      btn.addEventListener('mousemove', (e) => {
        const rect = btn.getBoundingClientRect()
        const cx = rect.left + rect.width / 2
        const cy = rect.top + rect.height / 2
        const dx = e.clientX - cx
        const dy = e.clientY - cy
        const dist = Math.hypot(dx, dy)
        if (dist < rect.width / 2 + RADIUS) {
          btn.style.transform = `translate(${dx * STRENGTH}px, ${dy * STRENGTH}px)`
        }
      })
      btn.addEventListener('mouseleave', () => {
        btn.style.transform = ''
      })
    })

    // Tilt cards — preserve existing lift
    document.querySelectorAll<HTMLElement>('[data-tilt]').forEach((card) => {
      const MAX = 2.5
      const LIFT = card.classList.contains('hover:-translate-y-1') ? 4 : 2
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect()
        const px = (e.clientX - rect.left) / rect.width
        const py = (e.clientY - rect.top) / rect.height
        const rx = (0.5 - py) * MAX * 2
        const ry = (px - 0.5) * MAX * 2
        card.style.transform = `perspective(1000px) rotateX(${rx}deg) rotateY(${ry}deg) translateY(-${LIFT}px)`
      })
      card.addEventListener('mouseleave', () => {
        card.style.transform = ''
      })
    })

    // Underline swipe leave direction
    document.querySelectorAll<HTMLElement>('.link-swipe').forEach((link) => {
      link.addEventListener('mouseleave', () => {
        link.classList.add('is-leaving')
        setTimeout(() => link.classList.remove('is-leaving'), 400)
      })
    })
  }

  // Hero dissolve on scroll (Ideia 3)
  const dissolveEls = document.querySelectorAll<HTMLElement>('[data-dissolve]')
  if (dissolveEls.length && !reducedMotion) {
    let ticking = false
    const update = () => {
      dissolveEls.forEach((el) => {
        const rect = el.getBoundingClientRect()
        const vh = window.innerHeight
        const progress = Math.min(1, Math.max(0, -rect.top / vh))
        const opacity = 1 - progress * 0.95
        const translate = -progress * 28
        el.style.opacity = String(opacity)
        el.style.transform = `translateY(${translate}px)`
      })
      ticking = false
    }
    const onScroll = () => {
      if (!ticking) {
        requestAnimationFrame(update)
        ticking = true
      }
    }
    update()
    window.addEventListener('scroll', onScroll, { passive: true })
    window.addEventListener('resize', onScroll)
  }
</script>
