---
import { getTranslations, getLocalePath, type Locale } from '../../i18n/index'
import Button from '../ui/Button.astro'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const t = getTranslations(locale)

const home = getLocalePath(locale)
const navLinks = [
  { label: t.nav.about, href: `${home}#about` },
  { label: t.nav.portfolio, href: `${home}#portfolio` },
  { label: t.nav.articles, href: getLocalePath(locale, 'articles/') },
]

const localeLinks = [
  { locale: 'pt' as Locale, label: 'PT' },
  { locale: 'en' as Locale, label: 'EN' },
  { locale: 'es' as Locale, label: 'ES' },
]
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-dark-border bg-dark/90 backdrop-blur-sm px-6 md:px-12 lg:px-24">
  <div class="max-w-5xl mx-auto h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href={getLocalePath(locale)} class="font-display text-dark-text font-bold text-lg italic hover:text-accent transition-colors">
      Wildiney Di Masi
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="text-sm text-muted hover:text-dark-text transition-colors tracking-wide uppercase"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right: locale switcher + contact CTA -->
    <div class="hidden md:flex items-center gap-4">
      <!-- Locale switcher -->
      <div class="flex items-center gap-1 text-xs">
        {localeLinks.map((l, i) => (
          <>
            <a
              href={getLocalePath(l.locale)}
              class:list={[
                'tracking-widest transition-colors',
                l.locale === locale ? 'text-dark-text font-semibold' : 'text-muted hover:text-dark-text',
              ]}
            >
              {l.label}
            </a>
            {i < localeLinks.length - 1 && <span class="text-dark-border">·</span>}
          </>
        ))}
      </div>

      <!-- Contact CTA -->
      <Button href={`${home}#contact`} variant="primary" size="sm">{t.nav.contact}</Button>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-muted hover:text-dark-text transition-colors"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>
</header>

<!-- Mobile Menu -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-dark flex-col items-center justify-center hidden"
  aria-hidden="true"
>
  <button
    id="mobile-menu-close"
    class="absolute top-5 right-6 text-muted hover:text-dark-text transition-colors"
    aria-label="Close menu"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="18" y1="6" x2="6" y2="18" />
      <line x1="6" y1="6" x2="18" y2="18" />
    </svg>
  </button>

  <nav class="flex flex-col items-center gap-8 text-center">
    {navLinks.map(link => (
      <a
        href={link.href}
        class="mobile-menu-link font-display text-2xl text-dark-text hover:text-accent transition-colors"
      >
        {link.label}
      </a>
    ))}
    <Button href={`${home}#contact`} variant="primary" size="lg" class="mobile-menu-link mt-4">{t.nav.contact}</Button>
    <!-- Locale switcher -->
    <div class="flex gap-4 text-sm mt-4">
      {localeLinks.map(l => (
        <a
          href={getLocalePath(l.locale)}
          class:list={[
            'tracking-widest transition-colors',
            l.locale === locale ? 'text-dark-text font-semibold' : 'text-muted hover:text-dark-text',
          ]}
        >
          {l.label}
        </a>
      ))}
    </div>
  </nav>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const closeBtn = document.getElementById('mobile-menu-close')
  const menu = document.getElementById('mobile-menu')

  function openMenu() {
    menu?.classList.remove('hidden')
    menu?.classList.add('flex')
    menu?.setAttribute('aria-hidden', 'false')
    btn?.setAttribute('aria-expanded', 'true')
    document.body.style.overflow = 'hidden'
  }

  function closeMenu() {
    menu?.classList.add('hidden')
    menu?.classList.remove('flex')
    menu?.setAttribute('aria-hidden', 'true')
    btn?.setAttribute('aria-expanded', 'false')
    document.body.style.overflow = ''
  }

  btn?.addEventListener('click', openMenu)
  closeBtn?.addEventListener('click', closeMenu)

  // Close on nav link click
  document.querySelectorAll('.mobile-menu-link').forEach(link => {
    link.addEventListener('click', closeMenu)
  })
</script>
