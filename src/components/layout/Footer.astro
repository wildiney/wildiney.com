---
import { type Locale } from '../../i18n/index'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const year = new Date().getFullYear()
---

<footer class="bg-dark border-t border-dark-border py-8 px-6 md:px-12 lg:px-24">
  <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex flex-col md:flex-row items-center gap-2 text-sm text-muted">
      <span class="font-display italic text-dark-text">Wildiney Di Masi</span>
      <span class="hidden md:inline text-dark-border">·</span>
      <span>© {year} · Feito com curiosidade e cuidado</span>
    </div>

    <div class="flex items-center gap-6">
      <a
        href="https://linkedin.com/in/wildiney"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-muted hover:text-accent transition-colors tracking-widest uppercase"
      >
        LinkedIn
      </a>
      <a
        href="https://github.com/wildiney"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-muted hover:text-accent transition-colors tracking-widest uppercase"
      >
        GitHub
      </a>
    </div>
  </div>
</footer>
