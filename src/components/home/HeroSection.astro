---
import Button from '../ui/Button.astro'
import { getLocalePath, type Locale } from '../../i18n/index'

interface Props { locale: Locale }
const { locale } = Astro.props

const heroCopy = {
  pt: {
    label: 'Product Manager · Designer',
    headline: 'PM com DNA\nde designer.',
    sub: 'Transformo visão em entrega. Design como ferramenta, dados como bússola, impacto como medida.',
    cta1: 'Ver trabalhos',
    cta2: 'Entrar em contato',
    scroll: 'Role para explorar',
  },
  en: {
    label: 'Product Manager · Designer',
    headline: "PM with a\ndesigner's DNA.",
    sub: 'I turn vision into delivery. Design as a tool, data as compass, impact as measure.',
    cta1: 'See work',
    cta2: 'Get in touch',
    scroll: 'Scroll to explore',
  },
  es: {
    label: 'Product Manager · Diseñador',
    headline: 'PM con ADN\nde diseñador.',
    sub: 'Transformo visión en entrega. Diseño como herramienta, datos como brújula, impacto como medida.',
    cta1: 'Ver trabajos',
    cta2: 'Contactar',
    scroll: 'Desplázate para explorar',
  },
}
const copy = heroCopy[locale]

const projects = [
  {
    num: '01',
    category: 'Gov Tech',
    title: 'Programa Bolsa Família',
    href: `${getLocalePath(locale)}portfolio/globalweb/bolsa-familia/`,
  },
  {
    num: '02',
    category: 'E-commerce',
    title: 'Sanrio Brasil',
    href: `${getLocalePath(locale)}portfolio/sanrio/ecommerce/`,
  },
  {
    num: '03',
    category: 'Branding & Produto',
    title: 'Indra / Minsait',
    href: `${getLocalePath(locale)}portfolio/indra/`,
  },
]
---

<section class="min-h-screen flex items-center bg-dark px-6 md:px-12 lg:px-24 pt-16">
  <div class="max-w-5xl mx-auto w-full py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">

      <!-- Left: Intro -->
      <div>
        <p class="text-xs text-accent uppercase tracking-widest mb-6">{copy.label}</p>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-black text-dark-text leading-tight mb-6">
          {copy.headline.split('\n').map((line, i) => (
            i < copy.headline.split('\n').length - 1 ? <>{line}<br/></> : <>{line}</>
          ))}
        </h1>
        <p class="text-muted text-lg leading-relaxed mb-10 max-w-sm">
          {copy.sub}
        </p>
        <div class="flex flex-wrap gap-4">
          <Button href="#portfolio" variant="primary">{copy.cta1}</Button>
          <Button href="#contact" variant="secondary">{copy.cta2}</Button>
        </div>
      </div>

      <!-- Right: Project cards -->
      <div class="flex flex-col gap-3">
        {projects.map(p => (
          <a
            href={p.href}
            class="group flex items-center justify-between border border-dark-border bg-dark-surface px-5 py-4 hover:border-accent transition-colors"
          >
            <div class="flex items-center gap-4">
              <span class="text-xs text-accent font-mono tracking-widest">{p.num}</span>
              <div>
                <p class="text-xs text-muted uppercase tracking-wider mb-1">{p.category}</p>
                <p class="text-sm font-semibold text-dark-text group-hover:text-accent transition-colors">{p.title}</p>
              </div>
            </div>
            <span class="text-muted group-hover:text-accent transition-colors text-lg">↗</span>
          </a>
        ))}
      </div>

    </div>

    <!-- Scroll indicator -->
    <div class="hidden md:flex flex-col items-center gap-2 mt-16 text-muted">
      <div class="w-px h-8 bg-accent"></div>
      <p class="text-xs uppercase tracking-widest">{copy.scroll}</p>
    </div>
  </div>
</section>
