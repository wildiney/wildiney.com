---
import { type Locale } from '../../i18n/index'
import Button from '../ui/Button.astro'

interface Props { locale: Locale }
const { locale } = Astro.props

const copy = {
  pt: {
    label: 'Contato',
    headline: 'Vamos conversar.',
    sub: 'Aberto a posições de Product Manager e Design Lead em empresas que levam produto a sério.',
    nameLabel: 'Nome',
    emailLabel: 'Email',
    messageLabel: 'Mensagem',
    namePlaceholder: 'Seu nome',
    emailPlaceholder: 'seu@email.com',
    messagePlaceholder: 'Como posso ajudar?',
    submit: 'Enviar mensagem',
    sending: 'Enviando...',
    successMsg: 'Mensagem enviada! Retorno em breve.',
    errorMsg: 'Erro ao enviar. Tente novamente.',
    tagline: 'Boas perguntas constroem bons produtos.',
  },
  en: {
    label: 'Contact',
    headline: "Let's talk.",
    sub: 'Open to Product Manager and Design Lead positions at companies that take product seriously.',
    nameLabel: 'Name',
    emailLabel: 'Email',
    messageLabel: 'Message',
    namePlaceholder: 'Your name',
    emailPlaceholder: 'you@email.com',
    messagePlaceholder: 'How can I help?',
    submit: 'Send message',
    sending: 'Sending...',
    successMsg: 'Message sent! I will get back to you soon.',
    errorMsg: 'Failed to send. Please try again.',
    tagline: 'Good questions build good products.',
  },
  es: {
    label: 'Contacto',
    headline: 'Hablemos.',
    sub: 'Abierto a posiciones de Product Manager y Design Lead en empresas que se toman el producto en serio.',
    nameLabel: 'Nombre',
    emailLabel: 'Email',
    messageLabel: 'Mensaje',
    namePlaceholder: 'Tu nombre',
    emailPlaceholder: 'tu@email.com',
    messagePlaceholder: '¿Cómo puedo ayudarte?',
    submit: 'Enviar mensaje',
    sending: 'Enviando...',
    successMsg: 'Mensaje enviado. Te respondo pronto.',
    errorMsg: 'Error al enviar. Intenta de nuevo.',
    tagline: 'Las buenas preguntas construyen buenos productos.',
  },
}
const c = copy[locale]
---

<section id="contact" class="bg-dark border-t border-dark-border py-24 px-6 md:px-12 lg:px-24">
  <div class="max-w-5xl mx-auto">
    <p class="text-xs text-accent uppercase tracking-widest mb-4">{c.label}</p>
    <h2 class="font-display text-4xl md:text-5xl font-black text-dark-text mb-6">{c.headline}</h2>
    <p class="text-muted text-lg leading-relaxed max-w-lg mb-10">{c.sub}</p>

    <form
      id="contact-form"
      class="flex flex-col gap-5 max-w-lg"
      data-success={c.successMsg}
      data-error={c.errorMsg}
      data-sending={c.sending}
      data-submit={c.submit}
    >
      <input type="text" name="_honey" style="display:none">

      <div class="flex flex-col gap-1.5">
        <label for="contact-name" class="text-xs text-muted uppercase tracking-widest">{c.nameLabel}</label>
        <input
          id="contact-name"
          type="text"
          name="name"
          placeholder={c.namePlaceholder}
          required
          class="bg-dark-surface border border-dark-border text-dark-text placeholder-muted px-4 py-3 text-sm focus:outline-none focus:border-accent transition-colors"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="contact-email" class="text-xs text-muted uppercase tracking-widest">{c.emailLabel}</label>
        <input
          id="contact-email"
          type="email"
          name="email"
          placeholder={c.emailPlaceholder}
          required
          class="bg-dark-surface border border-dark-border text-dark-text placeholder-muted px-4 py-3 text-sm focus:outline-none focus:border-accent transition-colors"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="contact-message" class="text-xs text-muted uppercase tracking-widest">{c.messageLabel}</label>
        <textarea
          id="contact-message"
          name="message"
          placeholder={c.messagePlaceholder}
          required
          rows="5"
          class="bg-dark-surface border border-dark-border text-dark-text placeholder-muted px-4 py-3 text-sm focus:outline-none focus:border-accent transition-colors resize-none"
        ></textarea>
      </div>

      <Button id="contact-submit" type="submit" variant="primary" class="self-start">{c.submit}</Button>
    </form>

  </div>
</section>

<!-- Toast -->
<div
  id="contact-toast"
  role="status"
  aria-live="polite"
  class="fixed bottom-6 right-6 z-50 px-5 py-3 text-sm font-sans font-medium tracking-wide transition-all duration-300 opacity-0 translate-y-2 pointer-events-none"
></div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null
  const toast = document.getElementById('contact-toast') as HTMLElement | null
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null

  if (form && toast && submitBtn) {
    let toastTimer: ReturnType<typeof setTimeout>

    function showToast(message: string, isSuccess: boolean) {
      clearTimeout(toastTimer)
      toast!.textContent = message
      toast!.className = [
        'fixed bottom-6 right-6 z-50 px-5 py-3 text-sm font-sans font-medium tracking-wide',
        'transition-all duration-300',
        isSuccess
          ? 'bg-accent text-ink'
          : 'bg-dark-surface border border-dark-border text-dark-text',
      ].join(' ')
      // Trigger enter
      requestAnimationFrame(() => {
        toast!.classList.remove('opacity-0', 'translate-y-2')
        toast!.classList.add('opacity-100', 'translate-y-0')
      })
      toastTimer = setTimeout(() => {
        toast!.classList.remove('opacity-100', 'translate-y-0')
        toast!.classList.add('opacity-0', 'translate-y-2')
      }, 4000)
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault()

      // Honeypot check
      const honey = form.querySelector<HTMLInputElement>('[name="_honey"]')
      if (honey?.value) return

      const sendingText = form.dataset.sending ?? '...'
      const successText = form.dataset.success ?? 'Sent!'
      const errorText = form.dataset.error ?? 'Error.'
      const submitText = form.dataset.submit ?? 'Send'

      submitBtn.disabled = true
      submitBtn.textContent = sendingText

      try {
        const data = new FormData(form)
        const res = await fetch('https://formsubmit.co/ajax/wildiney@gmail.com', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: data,
        })
        const json = await res.json()
        if (json.success === 'true' || json.success === true) {
          showToast(successText, true)
          form.reset()
        } else {
          showToast(errorText, false)
        }
      } catch {
        showToast(errorText, false)
      } finally {
        submitBtn.disabled = false
        submitBtn.textContent = submitText
      }
    })
  }
</script>
