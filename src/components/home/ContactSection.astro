---
import Button from '../ui/Button.astro'
import { type Locale } from '../../i18n/index'

interface Props { locale: Locale }
const { locale } = Astro.props
---

<section id="contact" class="bg-dark border-t border-dark-border py-24 px-6 md:px-12 lg:px-24">
  <div class="max-w-5xl mx-auto">
    <p class="text-xs text-accent uppercase tracking-widest mb-4">Contato</p>
    <h2 class="font-display text-4xl md:text-5xl font-black text-dark-text mb-6">Vamos conversar.</h2>
    <p class="text-muted text-lg leading-relaxed max-w-lg mb-10">
      Aberto a projetos, colaborações e boas conversas sobre produto.
    </p>
    <Button href="https://forms.gle/placeholder" variant="primary" class="text-base px-8 py-4">
      Entre em contato →
    </Button>
  </div>
</section>
