---
interface Props {
  id?: string
  light?: boolean
  surface?: boolean
  class?: string
}
const { id, light = false, surface = false, class: className } = Astro.props

const bg = light ? 'bg-paper text-ink' : surface ? 'bg-dark-surface text-dark-text' : 'bg-dark text-dark-text'
---
<section
  id={id}
  class:list={['py-20 px-6 md:px-12 lg:px-24', bg, className]}
>
  <div class="max-w-5xl mx-auto">
    <slot />
  </div>
</section>
