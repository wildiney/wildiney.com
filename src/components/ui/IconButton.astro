---
interface Props {
  href?: string
  label: string
  size?: 'sm' | 'md' | 'lg'
  class?: string
  [key: string]: unknown
}
const { href, label, size = 'md', class: className, ...rest } = Astro.props

const sizes = { sm: 'w-8 h-8', md: 'w-10 h-10', lg: 'w-12 h-12' }
const classes = ['rounded-full flex items-center justify-center text-muted hover:text-dark-text transition-colors', sizes[size], className].filter(Boolean).join(' ')
---
{href ? (
  <a href={href} aria-label={label} class={classes} {...rest}><slot /></a>
) : (
  <button aria-label={label} class={classes} {...rest}><slot /></button>
)}
